"" Leader run mode.
call MapGroupWithDescriptions('<leader>r', 'run', [
    \[['map'], 'r', '<Action>(Run)', 'Launch current run target'],
    \[['map'], 'l', '<Action>(RunAnything)', 'Launch run target'],
    \[['map'], 'p', '<Action>(Rerun)', 'Launch previous run target'],
