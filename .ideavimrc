call MapGroupWithDescriptions('<leader>p', 'project', [
    \[['map'], 'p', '<Action>(ManageRecentProjects)', 'Switch projects'],
    \[['map'], 't', '<Action>(ActivateTODOToolWindow)', 'Show TODOs'],
